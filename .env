# ================================
# Docker Compose 环境变量配置文件
# ================================

# -------------------- 路径配置 --------------------
# 媒体文件存储路径（影视、视频等）
MEDIA_PATH=/vol2/1000/media

# 音乐文件存储路径
MUSIC_PATH=/vol2/1000/music

# -------------------- 用户配置 --------------------
# 运行容器的用户ID和组ID
PUID=1000
PGID=1000

# -------------------- 时区配置 --------------------
TZ=Asia/Shanghai

# -------------------- 网络配置 --------------------
# Docker 网络子网段
NETWORK_SUBNET=172.20.0.0

# -------------------- 数据库配置 --------------------
# PostgreSQL 配置（MoviePilot）
POSTGRES_DB=moviepilot
POSTGRES_USER=moviepilot
POSTGRES_PASSWORD=pg_password

# MySQL 配置（PanCheck）
MYSQL_ROOT_PASSWORD=root123
MYSQL_DATABASE=pancheck

# Redis 配置（共享）
REDIS_PASSWORD=123456

# -------------------- 应用密码配置 --------------------
# MoviePilot 超级管理员
MOVIEPILOT_SUPERUSER=admin
MOVIEPILOT_SUPERUSER_PASSWORD=admin123

# Quark Auto Save
QUARK_WEBUI_USERNAME=admin
QUARK_WEBUI_PASSWORD=admin123

# PanCheck 管理员密码
PANCHECK_ADMIN_PASSWORD=admin123

# PlaylistDL 管理员
PLAYLISTDL_ADMIN_USERNAME=yukun
PLAYLISTDL_ADMIN_PASSWORD=yukun12

# Solara Music
SOLARA_PASSWORD=solara123
SOLARA_SESSION_SECRET=KLmlKDruIBRYjrT5ct7B3xqG25ZF2p59

# -------------------- 端口配置 --------------------
# Qbittorrent
QBITTORRENT_WEBUI_PORT=8080
QBITTORRENT_BT_PORT=6881

# MoviePilot
MOVIEPILOT_NGINX_PORT=3003
MOVIEPILOT_API_PORT=3011

# IPTV API
IPTV_API_PORT=9000

# Navidrome
NAVIDROME_PORT=4533

# Music Tag Web
MUSIC_TAG_PORT=8008

# Quark Auto Save
QUARK_PORT=5005

# CloudSaver
CLOUDSAVER_PORT=8009

# PanCheck
PANCHECK_PORT=8081

# PanSou
PANSOU_HTTP_PORT=8888
PANSOU_HTTPS_PORT=441

# Omnibox
OMNIBOX_PORT=7023

# Sun Panel
SUNPANEL_PORT=13002

# XiaoMusic
XIAOMUSIC_PORT=58090

# PlaylistDL
PLAYLISTDL_PORT=4827

# Solara Music
SOLARA_MUSIC_PORT=3012

# Clash
CLASH_PROXY_PORT=7890
CLASH_UI_PORT=1123
CLASH_DNS_PORT=1053

# -------------------- 资源限制配置 --------------------
# 内存限制（可根据实际情况调整）
QBITTORRENT_MEM_LIMIT=2G
QBITTORRENT_MEM_RESERVATION=512M

MOVIEPILOT_MEM_LIMIT=4G
MOVIEPILOT_MEM_RESERVATION=1G

POSTGRESQL_MEM_LIMIT=1G
POSTGRESQL_MEM_RESERVATION=256M

REDIS_MEM_LIMIT=512M
REDIS_MEM_RESERVATION=128M

MYSQL_MEM_LIMIT=1G
MYSQL_MEM_RESERVATION=256M

# -------------------- 其他配置 --------------------
# Redis 最大内存
REDIS_MAXMEMORY=512mb

# PanSou 域名配置
PANSOU_DOMAIN=localhost
PANSOU_HOST=127.0.0.1
